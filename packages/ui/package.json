{
  "name": "@ui/lib",
  "version": "0.0.1",
  "description": "Vue 3 UI (Button, Icon), vue-i18n (tr), theme CSS, Tailwind preset",
  "type": "module",
  "sideEffects": [
    "./themes/*.css",
    "./themes/components/*.css"
  ],
  "files": [
    "dist",
    "themes",
    "tailwind-preset.cjs"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./landing": {
      "import": "./dist/landing.js"
    },
    "./style.css": "./themes/default.css",
    "./components.css": "./themes/components.css",
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "vite build"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.11",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "vue-router": "^5.0.3"
  }
}
